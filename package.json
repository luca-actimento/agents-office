{
  "name": "agents-office",
  "displayName": "Agents Office",
  "description": "A living pixel-art office for your AI coding agents — watch them work, grab coffee, and wait for your permission",
  "version": "1.0.1",
  "author": "Luca Graeser",
  "publisher": "luca-actimento",
  "repository": {
    "type": "git",
    "url": "https://github.com/luca-actimento/agents-office"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agents-office.showPanel",
        "title": "Agents Office: Show Panel"
      },
      {
        "command": "agents-office.exportDefaultLayout",
        "title": "Agents Office: Export Layout as Default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agents-office-panel",
          "title": "Agents Office",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "agents-office-panel": [
        {
          "type": "webview",
          "id": "agents-office.panelView",
          "name": "Agents Office"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/import-tileset-cli.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
